rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function role() {
      return signedIn() ? userDoc(request.auth.uid).data.role : null;
    }

    function isPatient() {
      return role() == 'patient';
    }

    function isCaretaker() {
      return role() == 'caretaker';
    }

    function isDoctor() {
      return role() == 'doctor';
    }

    function affectsOnly(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    function isLinkedCaretakerViaUsers(patientId) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(patientId))
        && get(/databases/$(database)/documents/users/$(patientId)).data.caretakerIds is list
        && request.auth.uid in get(/databases/$(database)/documents/users/$(patientId)).data.caretakerIds;
    }

    // Back-compat: some environments store caretakerIds on /patients/{patientId}.
    function isLinkedCaretakerViaPatients(patientId) {
      return signedIn()
        && exists(/databases/$(database)/documents/patients/$(patientId))
        && get(/databases/$(database)/documents/patients/$(patientId)).data.caretakerIds is list
        && request.auth.uid in get(/databases/$(database)/documents/patients/$(patientId)).data.caretakerIds;
    }

    function isLinkedCaretaker(patientId) {
      return isCaretaker() && (isLinkedCaretakerViaUsers(patientId) || isLinkedCaretakerViaPatients(patientId));
    }

    function isLinkedDoctor(patientId) {
      return signedIn()
        && isDoctor()
        && exists(/databases/$(database)/documents/patients/$(patientId))
        && get(/databases/$(database)/documents/patients/$(patientId)).data.doctorIds is list
        && request.auth.uid in get(/databases/$(database)/documents/patients/$(patientId)).data.doctorIds;
    }

    // ---- users ----
    match /users/{uid} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == uid;
      // Users can edit their own user doc.
      allow update, delete: if signedIn() && request.auth.uid == uid;

      // Caretakers/Doctors can link themselves to a patient.
      allow update: if signedIn()
        && (isCaretaker() || isDoctor())
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['caretakerIds', 'doctorIds']);

      // Caretakers can link a doctor to a patient (or doctors can link themselves)
      allow update: if signedIn()
        && (isCaretaker() || isDoctor())
        && request.resource.data.diff(resource.data).affectedKeys().hasAny(['doctorIds', 'patientIds'])
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['doctorIds', 'patientIds', 'updatedAt']);
    }

    // ---- patients ----
    match /patients/{patientId} {
      allow read: if signedIn() && (request.auth.uid == patientId || isLinkedCaretaker(patientId) || isLinkedDoctor(patientId));

      // Patient creates/updates own profile doc.
      allow create, update: if signedIn() && request.auth.uid == patientId;

      // Caretaker/Doctor can link themselves to a patient.
      allow update: if signedIn()
        && (isCaretaker() || isDoctor())
        && request.resource.data.diff(resource.data).affectedKeys().hasAny(['caretakerIds', 'doctorIds'])
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['caretakerIds', 'doctorIds', 'name', 'email', 'updatedAt', 'patientId']);

      // Caretaker can link a doctor to their patient
      allow update: if signedIn()
        && isCaretaker()
        && isLinkedCaretaker(patientId)
        && request.resource.data.diff(resource.data).affectedKeys().hasAny(['doctorIds'])
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['doctorIds', 'updatedAt', 'patientId']);

      allow delete: if false;
    }

    // ---- medicines ----
    match /medicines/{medicineId} {
      allow read: if signedIn() && (
        (isPatient() && resource.data.patientId == request.auth.uid) ||
        isLinkedCaretaker(resource.data.patientId) ||
        isLinkedDoctor(resource.data.patientId)
      );

      allow create, update, delete: if signedIn()
        && isCaretaker()
        && request.resource.data.patientId is string
        && isLinkedCaretaker(request.resource.data.patientId);
    }

    // ---- adherence logs ----
    match /adherenceLogs/{logId} {
      allow read: if signedIn() && (
        (isPatient() && resource.data.patientId == request.auth.uid) ||
        isLinkedCaretaker(resource.data.patientId) ||
        isLinkedDoctor(resource.data.patientId)
      );

      allow create: if signedIn()
        && isCaretaker()
        && request.resource.data.patientId is string
        && isLinkedCaretaker(request.resource.data.patientId);

      allow update, delete: if false;
    }

    // ---- chats ----
    match /chats/{patientId} {
      // We don't store fields at /chats/{patientId} yet; gate access through subcollection.
      allow read: if false;
      allow write: if false;

      match /messages/{messageId} {
        allow read: if signedIn() && (
          request.auth.uid == patientId || isLinkedCaretaker(patientId)
        );

        allow create: if signedIn() && (
          request.auth.uid == patientId || isLinkedCaretaker(patientId)
        );

        allow update, delete: if false;
      }
    }

    // Optional (existing feature): patient_logs written by caretakers.
    match /patient_logs/{logId} {
      allow read: if signedIn() && (
        (isPatient() && resource.data.patientId == request.auth.uid) ||
        isLinkedCaretaker(resource.data.patientId) ||
        isLinkedDoctor(resource.data.patientId)
      );
      allow create: if signedIn() && isCaretaker() && isLinkedCaretaker(request.resource.data.patientId);
      allow update, delete: if false;
    }

    // ---- prescriptions ----
    match /prescriptions/{prescriptionId} {
      allow read: if signedIn() && (
        (isPatient() && resource.data.patientId == request.auth.uid) ||
        isLinkedCaretaker(resource.data.patientId) ||
        isLinkedDoctor(resource.data.patientId)
      );

      // Allowing caretakers to create/update prescriptions as per decision
      allow create, update: if signedIn() && isCaretaker() && isLinkedCaretaker(request.resource.data.patientId);
      allow delete: if signedIn() && isCaretaker() && isLinkedCaretaker(resource.data.patientId);
    }
  }
}

