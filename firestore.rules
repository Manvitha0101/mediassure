rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function role() {
      return signedIn() ? userDoc(request.auth.uid).data.role : null;
    }

    function isPatient() {
      return role() == 'patient';
    }

    function isCaretaker() {
      return role() == 'caretaker';
    }

    function affectsOnly(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    function isLinkedCaretakerViaUsers(patientId) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(patientId))
        && get(/databases/$(database)/documents/users/$(patientId)).data.caretakerIds is list
        && request.auth.uid in get(/databases/$(database)/documents/users/$(patientId)).data.caretakerIds;
    }

    // Back-compat: some environments store caretakerIds on /patients/{patientId}.
    function isLinkedCaretakerViaPatients(patientId) {
      return signedIn()
        && exists(/databases/$(database)/documents/patients/$(patientId))
        && get(/databases/$(database)/documents/patients/$(patientId)).data.caretakerIds is list
        && request.auth.uid in get(/databases/$(database)/documents/patients/$(patientId)).data.caretakerIds;
    }

    function isLinkedCaretaker(patientId) {
      return isCaretaker() && (isLinkedCaretakerViaUsers(patientId) || isLinkedCaretakerViaPatients(patientId));
    }

    // ---- users ----
    match /users/{uid} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == uid;
      // Users can edit their own user doc.
      allow update, delete: if signedIn() && request.auth.uid == uid;

      // Caretakers can link themselves to a patient by adding their uid to /users/{patientUid}.caretakerIds.
      // This is required for linked-patient authorization across the app.
      allow update: if signedIn()
        && isCaretaker()
        && affectsOnly(['caretakerIds'])
        && request.resource.data.caretakerIds is list
        && request.auth.uid in request.resource.data.caretakerIds;
    }

    // ---- patients ----
    match /patients/{patientId} {
      allow read: if signedIn() && (request.auth.uid == patientId || isLinkedCaretaker(patientId));

      // Patient creates/updates own profile doc.
      allow create, update: if signedIn() && request.auth.uid == patientId;

      // Caretaker can link themselves by adding their uid to caretakerIds.
      allow update: if signedIn()
        && isCaretaker()
        && request.resource.data.caretakerIds is list
        && request.auth.uid in request.resource.data.caretakerIds;

      allow delete: if false;
    }

    // ---- medicines ----
    match /medicines/{medicineId} {
      allow read: if signedIn() && (
        (isPatient() && resource.data.patientId == request.auth.uid) ||
        isLinkedCaretaker(resource.data.patientId)
      );

      allow create, update, delete: if signedIn()
        && isCaretaker()
        && request.resource.data.patientId is string
        && isLinkedCaretaker(request.resource.data.patientId);
    }

    // ---- adherence logs ----
    match /adherenceLogs/{logId} {
      allow read: if signedIn() && (
        (isPatient() && resource.data.patientId == request.auth.uid) ||
        isLinkedCaretaker(resource.data.patientId)
      );

      allow create: if signedIn()
        && isCaretaker()
        && request.resource.data.patientId is string
        && isLinkedCaretaker(request.resource.data.patientId);

      allow update, delete: if false;
    }

    // ---- chats ----
    match /chats/{patientId} {
      // We don't store fields at /chats/{patientId} yet; gate access through subcollection.
      allow read: if false;
      allow write: if false;

      match /messages/{messageId} {
        allow read: if signedIn() && (
          request.auth.uid == patientId || isLinkedCaretaker(patientId)
        );

        allow create: if signedIn() && (
          request.auth.uid == patientId || isLinkedCaretaker(patientId)
        );

        allow update, delete: if false;
      }
    }

    // Optional (existing feature): patient_logs written by caretakers.
    match /patient_logs/{logId} {
      allow read: if signedIn() && (
        (isPatient() && resource.data.patientId == request.auth.uid) ||
        isLinkedCaretaker(resource.data.patientId)
      );
      allow create: if signedIn() && isCaretaker() && isLinkedCaretaker(request.resource.data.patientId);
      allow update, delete: if false;
    }
  }
}

